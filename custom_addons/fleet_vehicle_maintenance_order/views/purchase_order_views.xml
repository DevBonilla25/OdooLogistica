<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_fleet_maintenance" model="ir.ui.view">
        <field name="name">purchase.order.form.fleet.maintenance</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_fleet_maintenance_order"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-wrench"
                        invisible="not fleet_maintenance_order_id">
                    <div class="o_field_statinfo">
                        <span class="o_stat_text">Orden mant.</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="fleet_maintenance_order_id" readonly="1"/>
                <field name="fleet_vehicle_id" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="after">
                <field name="fleet_maintenance_part_line_id" optional="hide" readonly="1"/>
                <field name="fleet_vehicle_id" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
