<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_vehicle_system_list" model="ir.ui.view">
        <field name="name">fleet.vehicle.system.list</field>
        <field name="model">fleet.vehicle.system</field>
        <field name="arch" type="xml">
            <list string="Sistemas vehiculares" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_vehicle_system_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.system.form</field>
        <field name="model">fleet.vehicle.system</field>
        <field name="arch" type="xml">
            <form string="Sistema vehicular">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_vehicle_system" model="ir.actions.act_window">
        <field name="name">Sistemas vehiculares</field>
        <field name="res_model">fleet.vehicle.system</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_fleet_vehicle_maintenance_order_list" model="ir.ui.view">
        <field name="name">fleet.vehicle.maintenance.order.list</field>
        <field name="model">fleet.vehicle.maintenance.order</field>
        <field name="arch" type="xml">
            <list string="Ordenes de mantenimiento" decoration-muted="state == 'cancelled'" decoration-success="state == 'closed'" decoration-warning="state in ('approval', 'parts_pending')">
                <field name="name"/>
                <field name="request_date"/>
                <field name="vehicle_id"/>
                <field name="reporter_id"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="odometer"/>
                <field name="system_ids" widget="many2many_tags"/>
                <field name="stock_move_count"/>
                <field name="purchase_order_count"/>
                <field name="total_cost" widget="monetary"/>
                <field name="state" widget="badge" decoration-info="state in ('reported', 'diagnosis')" decoration-warning="state in ('approval', 'parts_pending')" decoration-success="state in ('finished', 'closed')" decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_vehicle_maintenance_order_search" model="ir.ui.view">
        <field name="name">fleet.vehicle.maintenance.order.search</field>
        <field name="model">fleet.vehicle.maintenance.order</field>
        <field name="arch" type="xml">
            <search string="Buscar ordenes de mantenimiento">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="reporter_id"/>
                <field name="responsible_id"/>
                <field name="system_ids"/>
                <filter string="Abiertas" name="open" domain="[('state', 'not in', ('closed', 'cancelled'))]"/>
                <filter string="Pendiente de aprobacion" name="pending_approval" domain="[('state', '=', 'approval')]"/>
                <filter string="Pendiente de repuestos" name="waiting_parts" domain="[('state', '=', 'parts_pending')]"/>
                <filter string="Cerradas" name="closed" domain="[('state', '=', 'closed')]"/>
                <filter string="Canceladas" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Vehiculo" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Responsable" name="group_responsible" context="{'group_by': 'responsible_id'}"/>
                <filter string="Mes de reporte" name="group_request_date" context="{'group_by': 'request_date:month'}"/>
            </search>
        </field>
    </record>

    <record id="view_fleet_vehicle_maintenance_order_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.maintenance.order.form</field>
        <field name="model">fleet.vehicle.maintenance.order</field>
        <field name="arch" type="xml">
            <form string="Orden de mantenimiento">
                <header>
                    <button name="action_to_diagnosis" string="Iniciar diagnostico" type="object" class="btn-primary" invisible="state != 'reported'"/>
                    <button name="action_to_approval" string="Solicitar aprobacion" type="object" class="btn-primary" invisible="state != 'diagnosis'"/>
                    <button name="action_approve" string="Aprobar" type="object" class="btn-primary" invisible="state != 'approval'"/>
                    <button name="action_start_execution" string="Iniciar ejecucion" type="object" class="btn-primary" invisible="state not in ('approved', 'parts_pending')"/>
                    <button name="action_consume_stock_parts" string="Consumir repuestos" type="object" class="btn-primary" invisible="state not in ('approved', 'execution', 'parts_pending')"/>
                    <button name="action_create_parts_rfq" string="Crear RFQ de repuestos" type="object" class="btn-primary" invisible="state not in ('approval', 'approved', 'execution', 'parts_pending')"/>
                    <button name="action_parts_pending" string="Pendiente de repuestos" type="object" invisible="state not in ('approved', 'execution')"/>
                    <button name="action_finish" string="Finalizar" type="object" class="btn-primary" invisible="state != 'execution'"/>
                    <button name="action_close" string="Cerrar" type="object" class="btn-primary" invisible="state != 'finished'"/>
                    <button name="action_cancel" string="Cancelar" type="object" invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_reset_to_reported" string="Restablecer a reportada" type="object" invisible="state != 'cancelled'" groups="fleet.fleet_group_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="reported,diagnosis,approval,approved,execution,parts_pending,finished,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_stock_moves"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-exchange">
                            <field name="stock_move_count" widget="statinfo" string="Movimientos"/>
                        </button>
                        <button name="action_open_purchase_orders"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart">
                            <field name="purchase_order_count" widget="statinfo" string="Compras"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Solicitud">
                            <field name="vehicle_id"/>
                            <field name="reporter_id"/>
                            <field name="responsible_id" widget="many2one_avatar_user"/>
                            <field name="request_date"/>
                            <field name="odometer"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Fechas">
                            <field name="diagnosis_date" readonly="1"/>
                            <field name="approval_date" readonly="1"/>
                            <field name="start_date" readonly="1"/>
                            <field name="finish_date" readonly="1"/>
                            <field name="close_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Problema reportado">
                        <field name="problem_description" nolabel="1" placeholder="Describa la novedad reportada por el chofer o responsable."/>
                    </group>
                    <notebook>
                        <page string="Diagnostico" name="diagnosis">
                            <group>
                                <field name="system_ids" widget="many2many_checkboxes"/>
                            </group>
                            <group string="Diagnostico">
                                <field name="diagnosis" nolabel="1" placeholder="Registre el diagnostico del mecanico."/>
                            </group>
                        </page>
                        <page string="Actividades" name="activities">
                            <field name="activity_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="estimated_cost" widget="monetary"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Repuestos" name="parts">
                            <field name="part_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="source"/>
                                    <field name="suggested_vendor_id"/>
                                    <field name="purchase_qty"/>
                                    <field name="purchase_uom_id"/>
                                    <field name="estimated_purchase_price" widget="monetary"/>
                                    <field name="consume_from_stock"/>
                                    <field name="source_location_id"/>
                                    <field name="available_qty" readonly="1"/>
                                    <field name="purchase_state" readonly="1"/>
                                    <field name="purchase_order_id" readonly="1"/>
                                    <field name="purchase_order_line_id" readonly="1"/>
                                    <field name="price_unit" widget="monetary"/>
                                    <field name="subtotal" widget="monetary"/>
                                    <field name="consumed"/>
                                    <field name="consumed_cost" widget="monetary"/>
                                    <field name="stock_move_id" readonly="1"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Mano de obra" name="labor">
                            <field name="labor_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="technician_id"/>
                                    <field name="hours"/>
                                    <field name="rate" widget="monetary"/>
                                    <field name="fixed_cost" widget="monetary"/>
                                    <field name="subtotal" widget="monetary"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Costos" name="costs">
                            <group>
                                <group>
                                    <field name="activity_cost" widget="monetary"/>
                                    <field name="parts_cost" widget="monetary"/>
                                    <field name="consumed_parts_cost" widget="monetary"/>
                                    <field name="labor_cost" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="total_cost" widget="monetary"/>
                                </group>
                            </group>
                            <group string="Observaciones">
                                <field name="observations" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Inventario" name="inventory">
                            <field name="stock_move_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="reference"/>
                                    <field name="product_id"/>
                                    <field name="product_uom_qty"/>
                                    <field name="product_uom"/>
                                    <field name="location_id"/>
                                    <field name="location_dest_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Compras" name="purchases">
                            <field name="purchase_order_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="date_order"/>
                                    <field name="date_planned"/>
                                    <field name="amount_total" widget="monetary"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_fleet_vehicle_maintenance_order" model="ir.actions.act_window">
        <field name="name">Ordenes de mantenimiento</field>
        <field name="res_model">fleet.vehicle.maintenance.order</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_open': 1}</field>
    </record>

    <menuitem id="menu_fleet_vehicle_maintenance_order"
              name="Ordenes de mantenimiento"
              parent="fleet.fleet_vehicles"
              action="action_fleet_vehicle_maintenance_order"
              sequence="30"
              groups="fleet.fleet_group_user"/>

    <menuitem id="menu_fleet_vehicle_system"
              name="Sistemas vehiculares"
              parent="fleet.fleet_configuration"
              action="action_fleet_vehicle_system"
              sequence="30"
              groups="fleet.fleet_group_manager"/>
</odoo>
