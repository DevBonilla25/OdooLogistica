<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_orangehrm_user_sync_log_list" model="ir.ui.view">
        <field name="name">orangehrm.user.sync.log.list</field>
        <field name="model">orangehrm.user.sync.log</field>
        <field name="arch" type="xml">
            <list string="Logs OrangeHRM" decoration-success="state == 'success'" decoration-warning="state == 'warning'" decoration-danger="state == 'error'">
                <field name="sync_at"/>
                <field name="state" widget="badge" decoration-success="state == 'success'" decoration-warning="state == 'warning'" decoration-danger="state == 'error'"/>
                <field name="total_read"/>
                <field name="total_employees"/>
                <field name="total_fleet_drivers"/>
                <field name="total_salespersons"/>
                <field name="total_created"/>
                <field name="total_updated"/>
                <field name="total_skipped"/>
                <field name="error_count"/>
            </list>
        </field>
    </record>

    <record id="view_orangehrm_user_sync_log_form" model="ir.ui.view">
        <field name="name">orangehrm.user.sync.log.form</field>
        <field name="model">orangehrm.user.sync.log</field>
        <field name="arch" type="xml">
            <form string="Log OrangeHRM" create="0" edit="0">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sync_at"/>
                            <field name="state" widget="badge"/>
                        </group>
                        <group>
                            <field name="total_read"/>
                            <field name="total_employees"/>
                            <field name="total_fleet_drivers"/>
                            <field name="total_salespersons"/>
                            <field name="total_created"/>
                            <field name="total_updated"/>
                            <field name="total_skipped"/>
                            <field name="error_count"/>
                        </group>
                    </group>
                    <separator string="Mensaje"/>
                    <field name="message" nolabel="1" readonly="1" widget="text" style="white-space: pre-wrap; min-height: 160px; max-height: 320px; overflow-y: auto;"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_orangehrm_user_sync_log_search" model="ir.ui.view">
        <field name="name">orangehrm.user.sync.log.search</field>
        <field name="model">orangehrm.user.sync.log</field>
        <field name="arch" type="xml">
            <search string="Buscar logs OrangeHRM">
                <field name="name"/>
                <field name="message"/>
                <filter string="Correctos" name="success" domain="[('state', '=', 'success')]"/>
                <filter string="Advertencias" name="warning" domain="[('state', '=', 'warning')]"/>
                <filter string="Errores" name="error" domain="[('state', '=', 'error')]"/>
            </search>
        </field>
    </record>

    <record id="action_orangehrm_user_sync_log" model="ir.actions.act_window">
        <field name="name">Logs OrangeHRM</field>
        <field name="res_model">orangehrm.user.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
