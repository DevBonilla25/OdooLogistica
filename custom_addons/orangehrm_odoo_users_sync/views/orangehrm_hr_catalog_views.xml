<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_department_form_inherit_orangehrm_user_sync" model="ir.ui.view">
        <field name="name">hr.department.form.orangehrm.user.sync</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="OrangeHRM">
                    <field name="orangehrm_subunit_id" readonly="1"/>
                    <field name="orangehrm_unit_id" readonly="1"/>
                    <field name="orangehrm_level" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_hr_job_form_inherit_orangehrm_user_sync" model="ir.ui.view">
        <field name="name">hr.job.form.orangehrm.user.sync</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="OrangeHRM">
                    <field name="orangehrm_job_title_id" readonly="1"/>
                    <field name="orangehrm_job_description" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
