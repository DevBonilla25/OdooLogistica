<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="fleet_vehicle_view_form_inherit_maintenance_orders" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.maintenance.orders</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_maintenance_orders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-wrench">
                    <field name="maintenance_order_count" widget="statinfo" string="Ordenes mant."/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
